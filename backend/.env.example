# Variables de entorno para desarrollo local del backend (npm run dev).
# Copia a backend/.env y completa. Este archivo (.env) NO se sube a git.

# Terminal Hikvision
DEVICE_IP=192.168.0.16
DEVICE_USER=admin
DEVICE_PASS=la-contrasena-del-terminal

# Login del panel
