# Plantilla de variables de entorno para docker-compose.
# Copia este archivo a .env y completa los valores reales:
#   cp .env.example .env

# --- Terminal Hikvision ---
DEVICE_IP=192.168.0.16
DEVICE_USER=admin
DEVICE_PASS=la-contrasena-del-terminal

# --- Login del panel ---
# Secreto para firmar los tokens de sesión. Genera uno con:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=cambia-esto-por-un-secreto-aleatorio
# Hash bcrypt de la contraseña del panel. Genera uno con:
#   node -e "console.log(require('bcryptjs').hashSync('TU_CONTRASENA', 12))"
# Si lo dejas vacío, se usa el hash embebido por defecto (contraseña: maservit.1).
AUTH_PASSWORD_HASH=
